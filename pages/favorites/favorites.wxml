<!-- pages/favorites/favorites.wxml -->
<navigation-bar 
  title="我的收藏" 
  back="{{true}}"
  background="#ADD5A2" 
  color="#FFFFFF"
></navigation-bar>

<view class="favorites-container">
  
  <!-- 标签页导航 -->
  <view class="tabs-container">
    <scroll-view class="tabs-scroll" scroll-x>
      <view class="tabs">
        <view 
          wx:for="{{tabs}}" 
          wx:key="id"
          class="tab-item {{activeTab === item.id ? 'active' : ''}}"
          data-tab="{{item.id}}"
          bindtap="switchTab"
        >
          <text class="tab-icon">{{item.icon}}</text>
          <text class="tab-text">{{item.name}}</text>
          <text class="tab-count" wx:if="{{item.id === 'shops' && favoriteShops.length > 0}}">
            {{favoriteShops.length}}
          </text>
          <text class="tab-count" wx:if="{{item.id === 'photos' && favoritePhotos.length > 0}}">
            {{favoritePhotos.length}}
          </text>
          <text class="tab-count" wx:if="{{item.id === 'videos' && favoriteVideos.length > 0}}">
            {{favoriteVideos.length}}
          </text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar" wx:if="{{getCurrentTabStats() > 0}}">
    <text class="stats-text">共 {{getCurrentTabStats()}} 项</text>
    <view class="action-buttons">
      <text class="action-btn" bindtap="clearCurrentTabFavorites">清空</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 店铺收藏 -->
  <scroll-view 
    wx:if="{{activeTab === 'shops' && !isLoading}}" 
    class="content" 
    scroll-y
    enable-back-to-top
  >
    <view class="empty-state" wx:if="{{favoriteShops.length === 0}}">
      <image src="https://img.icons8.com/ios/100/cccccc/hearts.png" class="empty-icon" />
      <text class="empty-text">暂无收藏店铺</text>
      <text class="empty-tip">去首页发现美食并收藏吧~</text>
    </view>

    <view class="shop-list" wx:else>
      <view 
        class="shop-item" 
        wx:for="{{favoriteShops}}" 
        wx:key="id"
      >
        <view class="shop-main" bindtap="showShopDetail" data-shop="{{item}}">
          <image src="{{item.image}}" class="shop-image" mode="aspectFill" />
          <view class="shop-info">
            <text class="shop-name">{{item.name}}</text>
          </view>
        </view>
        <view 
          class="remove-btn" 
          bindtap="removeFavoriteShop"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          catchtap
        >
          <text>取消收藏</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 照片收藏 -->
  <scroll-view 
    wx:if="{{activeTab === 'photos' && !isLoading}}" 
    class="content" 
    scroll-y
  >
    <view class="empty-state" wx:if="{{favoritePhotos.length === 0}}">
      <image src="https://img.icons8.com/ios/100/cccccc/image.png" class="empty-icon" />
      <text class="empty-text">暂无收藏照片</text>
      <text class="empty-tip">去照片页面收藏喜欢的探店照片吧~</text>
    </view>

    <view class="photo-list" wx:else>
      <view class="photo-grid">
        <view 
          class="photo-item" 
          wx:for="{{favoritePhotos}}" 
          wx:key="id"
          bindtap="previewPhoto"
          data-index="{{index}}"
        >
          <view class="photo-wrapper">
            <image src="{{item.url}}" class="photo-thumb" mode="aspectFill" />
            <view class="photo-overlay">
              <text class="photo-title">{{item.title}}</text>
            </view>
          </view>
          <view 
            class="photo-remove-btn" 
            bindtap="removeFavoritePhoto"
            data-id="{{item.id}}"
            data-title="{{item.title}}"
            catchtap
          >
            <text>取消收藏</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  
  <!-- 视频收藏 -->
  <scroll-view 
    wx:if="{{activeTab === 'videos' && !isLoading}}" 
    class="content" 
    scroll-y
  >
    <view class="empty-state" wx:if="{{favoriteVideos.length === 0}}">
      <image src="https://img.icons8.com/ios/100/cccccc/video.png" class="empty-icon" />
      <text class="empty-text">暂无收藏视频</text>
      <text class="empty-tip">去视频页面收藏喜欢的探店视频吧~</text>
    </view>

    <view class="video-list" wx:else>
      <view 
        class="video-item" 
        wx:for="{{favoriteVideos}}" 
        wx:key="id"
      >
        <view class="video-main" bindtap="showVideoDetail" data-video="{{item}}">
          <image src="{{item.cover}}" class="video-cover" mode="aspectFill" />
          <view class="video-info">
            <text class="video-title">{{item.title}}</text>
            <text class="video-author">作者：{{item.author || '未知'}}</text>
            <text class="video-duration">时长：{{item.duration}}</text>
            <text class="video-stats">
              <text class="stat-item">👁️ {{item.viewCount || 0}}</text>
              <text class="stat-item">❤️ {{item.likeCount || 0}}</text>
            </text>
          </view>
        </view>
        <view 
          class="remove-btn" 
          bindtap="removeFavoriteVideo"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          catchtap
        >
          <text>取消收藏</text>
        </view>
      </view>
    </view>
  </scroll-view>

</view>