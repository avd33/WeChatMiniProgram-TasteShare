/* pages/favorites/favorites.wxss */
.favorites-container {
  min-height: 100vh;
  background: #F7F7F7;
}

/* 标签页导航 */
.tabs-container {
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 0 20rpx;
}

.tabs-scroll {
  width: 100%;
  /* 确保内容可以水平滚动 */
}

.tabs {
  display: flex;
  justify-content: space-around; 
  align-items: center; 
  width: 100%;
  padding: 20rpx 0;
}

.tab-item {
  display: flex; 
  flex-direction: column;
  align-items: center;
  padding: 0 15rpx; 
  position: relative;
  flex: 1; 
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

.tab-count {
  position: absolute;
  top: -15rpx;
  right: 20rpx;
  background: #FF672B;
  color: white;
  font-size: 30rpx;
  padding: 5rpx 8rpx;
  border-radius: 100rpx;
  min-width: 30rpx;
  min-height: 34rpx;
  text-align: center;
  line-height: 10rpx;
  box-sizing: border-box;
}

.tab-item.active .tab-text {
  color: #FF672B;
  font-weight: bold;
}

/* 操作栏（新增样式） */
.action-bar {
  background: white;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-text {
  font-size: 28rpx;
  color: #666;
}

.action-buttons {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #FF672B;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  background: #FFF5F0;
}

.action-btn.delete {
  color: #FF3B30;
  background: #FFF0F0;
}

/* 加载状态 */
.loading-container {
  text-align: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 内容区域 */
.content {
  height: calc(100vh - 200rpx);
  padding: 20rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
}

/* 店铺列表 */
.shop-item {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.shop-main {
  display: flex;
  padding: 30rpx;
  align-items: center;
}

.shop-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.shop-info {
  flex: 1;
  min-width: 0;
}

.shop-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-btn {
  padding: 20rpx;
  text-align: center;
  background: #f9f9f9;
  border-top: 1rpx solid #f0f0f0;
  color: #999;
  font-size: 26rpx;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding-top: 20rpx;
}

.photo-item {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.photo-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.photo-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
  padding: 20rpx;
  color: white;
}

.photo-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.photo-remove-btn {
  padding: 20rpx;
  text-align: center;
  background: #f9f9f9;
  border-top: 1rpx solid #f0f0f0;
  color: #999;
  font-size: 26rpx;
}

/* 视频列表 */
.video-list {
  padding: 20rpx;
}

.video-item {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.video-main {
  display: flex;
  padding: 30rpx;
  align-items: flex-start;
}

.video-cover {
  width: 200rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.video-info {
  flex: 1;
  min-width: 0;
}

.video-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}

.video-author {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.video-duration {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.video-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
}

.video-time {
  display: block;
  font-size: 22rpx;
  color: #ccc;
}

.remove-btn {
  padding: 20rpx;
  text-align: center;
  background: #f9f9f9;
  border-top: 1rpx solid #f0f0f0;
  color: #999;
  font-size: 26rpx;
}