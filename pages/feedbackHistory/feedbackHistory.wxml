<!-- pages/feedbackHistory/feedbackHistory.wxml -->
<navigation-bar 
  title="记录历史" 
  back="{{true}}"
  background="#ADD5A2" 
  color="#FFFFFF"
></navigation-bar>

<view class="feedback-history-container">
  
  <!-- 搜索和筛选栏 -->
  <view class="filter-section">
    <!-- 搜索框 -->
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="搜索菜品、记录内容或昵称" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <text 
        class="clear-btn" 
        wx:if="{{searchKeyword}}"
        bindtap="clearSearch"
      >
        清空
      </text>
    </view>

    <!-- 筛选标签 -->
    <scroll-view class="filter-tabs" scroll-x>
      <view class="filters">
        <view 
          class="filter-item {{filterStatus === 'all' ? 'active' : ''}}"
          data-status="all"
          bindtap="onFilterChange"
        >
          <text>全部</text>
        </view>
        <view 
          class="filter-item {{filterStatus === 'recent' ? 'active' : ''}}"
          data-status="recent"
          bindtap="onFilterChange"
        >
          <text>最近一周</text>
        </view>
        <view 
          class="filter-item {{filterStatus === 'strong' ? 'active' : ''}}"
          data-status="strong"
          bindtap="onFilterChange"
        >
          <text>强烈推荐</text>
        </view>
        <view 
          class="filter-item {{filterStatus === 'not' ? 'active' : ''}}"
          data-status="not"
          bindtap="onFilterChange"
        >
          <text>不太推荐</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 排序和操作栏 -->
  <view class="action-section">
    <view class="sort-options">
      <text class="sort-label">排序：</text>
      <text 
        class="sort-item {{sortBy === 'time' ? 'active' : ''}}"
        data-sort="time"
        bindtap="onSortChange"
      >
        时间 {{sortBy === 'time' ? (sortDesc ? '↓' : '↑') : ''}}
      </text>
      <text 
        class="sort-item {{sortBy === 'recommendation' ? 'active' : ''}}"
        data-sort="recommendation"
        bindtap="onSortChange"
      >
        推荐度 {{sortBy === 'recommendation' ? (sortDesc ? '↓' : '↑') : ''}}
      </text>
      <text 
        class="sort-item {{sortBy === 'dishName' ? 'active' : ''}}"
        data-sort="dishName"
        bindtap="onSortChange"
      >
        首字母顺序 {{sortBy === 'dishName' ? (sortDesc ? '↓' : '↑') : ''}}
      </text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons-section" wx:if="{{feedbackList.length > 0}}">
    <view class="action-buttons">
      <text class="action-btn export-btn" bindtap="exportFeedbackData">📋 导出数据</text>
      <text class="action-btn clear-btn" bindtap="clearAllFeedback">🗑️ 清空记录</text>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-info" wx:if="{{feedbackList.length > 0}}">
    <text>共 {{feedbackList.length}} 条美食记录</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{feedbackList.length === 0 && !isLoading}}">
    <image src="https://img.icons8.com/ios/100/ADD5A2/meal.png" class="empty-icon" />
    <text class="empty-text">暂无美食记录</text>
    <text class="empty-tip">去美食记录页面记录您的美食发现吧~</text>
    <view class="back-to-share" bindtap="goToShare">
      <text>立即记录</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <text class="loading-text">🍽️ 加载中...</text>
  </view>

  <!-- 记录列表 -->
  <scroll-view 
    class="feedback-list" 
    scroll-y
    enable-back-to-top
    wx:if="{{feedbackList.length > 0}}"
  >
    <view 
      class="feedback-item" 
      wx:for="{{feedbackList}}" 
      wx:key="index"
      data-item="{{item}}"
      data-index="{{index}}"
      bindtap="viewFeedbackDetail"
    >
      <view class="item-header">
        <text class="dish-name">{{item.dishName || '未命名菜品'}}</text>
        <view class="recommendation-icon">
          <text class="rec-icon">{{getRecommendationIcon(item.recommendation)}}</text>
          <text class="rec-text">{{getRecommendationText(item.recommendation)}}</text>
        </view>
      </view>
      
      <view class="item-content">
        <text class="feedback-preview">{{item.feedback || '无详细记录内容'}}</text>
      </view>
      
      <view class="item-footer">
        <view class="item-tags">
          <text class="tag user-tag" wx:if="{{item.name}}">👤 {{item.name}}</text>
          <text class="tag time-tag">🕒 {{item.formattedDate || formatTime(item.submitTime)}}</text>
        </view>
      </view>
      
      <view class="item-actions" catchtap>
        <view class="delete-btn" bindtap="deleteFeedbackItem" data-index="{{index}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </scroll-view>

</view>