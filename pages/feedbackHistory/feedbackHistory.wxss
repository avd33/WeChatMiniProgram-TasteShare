/* pages/feedbackHistory/feedbackHistory.wxss */
.feedback-history-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #F0F9F0, #E8F5E8);
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 搜索和筛选栏 */
.filter-section {
  background: linear-gradient(135deg, #FFFFFF, #FAFDFA);
  padding: 30rpx;
  border-radius: 0 0 28rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 213, 162, 0.15);
  margin-bottom: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFFFFF, #F8F9FA);
  border-radius: 20rpx;
  padding: 0 24rpx;
  border: 3rpx solid rgba(173, 213, 162, 0.3);
  margin-bottom: 30rpx;
  transition: all 0.3s;
}

.search-box:focus-within {
  border-color: #ADD5A2;
  box-shadow: 0 0 0 4rpx rgba(173, 213, 162, 0.2);
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  font-size: 24rpx;
  color: #ADD5A2;
  padding: 8rpx 16rpx;
  background: rgba(173, 213, 162, 0.1);
  border-radius: 12rpx;
  border: 2rpx solid rgba(173, 213, 162, 0.3);
}

.filter-tabs {
  white-space: nowrap;
}

.filters {
  display: inline-flex;
  gap: 20rpx;
}

.filter-item {
  display: inline-flex;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #F8F9FA, #FFFFFF);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid rgba(173, 213, 162, 0.3);
  transition: all 0.3s;
}

.filter-item.active {
  background: linear-gradient(135deg, #ADD5A2, #8BC34A);
  color: white;
  font-weight: 600;
  border-color: #ADD5A2;
  box-shadow: 0 4rpx 20rpx rgba(173, 213, 162, 0.3);
}

/* 操作栏 */
.action-section {
  background: linear-gradient(135deg, #FFFFFF, #FAFDFA);
  border-radius: 28rpx;
  padding: 30rpx;
  margin: 0 30rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 213, 162, 0.15);
  border: 3rpx solid rgba(173, 213, 162, 0.2);
}

.sort-options {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 20rpx;
}

.sort-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.sort-item {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 16rpx;

  background: linear-gradient(135deg, #F8F9FA, #FFFFFF);
  border-radius: 20rpx;
  border: 2rpx solid rgba(173, 213, 162, 0.3);
  transition: all 0.3s;
  min-height: 80rpx;
  text-align: center;
  line-height: 20rpx;
  box-sizing: border-box;
}

.sort-item.active {
  background: linear-gradient(135deg, #ADD5A2, #8BC34A);
  color: white;
  font-weight: 600;
  border-color: #ADD5A2;
  box-shadow: 0 4rpx 20rpx rgba(173, 213, 162, 0.3);
}

/* 操作按钮区域 */
.action-buttons-section {
  background: linear-gradient(135deg, #FFFFFF, #FAFDFA);
  border-radius: 28rpx;
  padding: 24rpx 30rpx;
  margin: 0 30rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 213, 162, 0.15);
  border: 3rpx solid rgba(173, 213, 162, 0.2);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  padding: 20rpx 0;
  border-radius: 20rpx;
  border: 2rpx solid rgba(173, 213, 162, 0.3);
  transition: all 0.3s;
}

.export-btn {
  background: linear-gradient(135deg, #ADD5A2, #8BC34A);
  color: white;
}

.export-btn:active {
  background: linear-gradient(135deg, #8BC34A, #689F38);
  transform: scale(0.98);
}

.clear-btn {
  background: linear-gradient(135deg, #FFE5E5, #FFCCCC);
  color: #FF6B6B;
  border-color: rgba(255, 107, 107, 0.3);
}

.clear-btn:active {
  background: linear-gradient(135deg, #FFCCCC, #FF9999);
  transform: scale(0.98);
}

/* 统计信息 */
.stats-info {
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #ADD5A2;
  font-weight: 600;
  background: rgba(173, 213, 162, 0.1);
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(173, 213, 162, 0.3);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 30rpx;
  background: linear-gradient(135deg, #FFFFFF, #FAFDFA);
  border-radius: 28rpx;
  margin: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 213, 162, 0.15);
  border: 3rpx solid rgba(173, 213, 162, 0.2);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.8;
  margin-bottom: 30rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.back-to-share {
  display: inline-block;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #ADD5A2, #8BC34A);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(173, 213, 162, 0.3);
  transition: all 0.3s;
}

.back-to-share:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(173, 213, 162, 0.3);
}

/* 加载状态 */
.loading-container {
  text-align: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #ADD5A2;
  font-weight: 600;
}

/* 记录列表 */
.feedback-list {
  height: calc(100vh - 650rpx);
  min-height: 400rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.feedback-list-container {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.feedback-item {
  background: linear-gradient(135deg, #FFFFFF, #FAFDFA);
  border-radius: 28rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 213, 162, 0.15);
  border: 3rpx solid rgba(173, 213, 162, 0.2);
  transition: transform 0.3s;
  width: 100%;
  box-sizing: border-box;
}

.feedback-item:active {
  transform: translateY(-4rpx);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .feedback-list {
    height: calc(100vh - 600rpx);
    padding: 0 20rpx;
  }
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx dashed rgba(173, 213, 162, 0.3);
}

.dish-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  word-break: break-all;
}

.recommendation-icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 8rpx;
}

.rec-icon {
  font-size: 32rpx;
}

.rec-text {
  font-size: 24rpx;
  color: #ADD5A2;
  font-weight: 600;
}

.item-content {
  margin-bottom: 30rpx;
}

.feedback-preview {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-footer {
  margin-bottom: 30rpx;
  width: 100%;
  display: flex;
  justify-content: flex-end;
}

.item-tags {
  display: flex;
  justify-content: flex-end;
  width: 100%;
}

.tag {
  font-size: 24rpx;
  color: #666;
  background: rgba(173, 213, 162, 0.1);
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(173, 213, 162, 0.3);
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.item-actions {
  border-top: 2rpx solid rgba(173, 213, 162, 0.2);
  padding-top: 30rpx;
  text-align: right;
}

.delete-btn {
  display: inline-block;
  font-size: 24rpx;
  color: #FF6B6B;
  padding: 12rpx 32rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.3);
  transition: all 0.3s;
}

.delete-btn:active {
  background: rgba(255, 107, 107, 0.2);
  transform: scale(0.98);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .filter-section,
  .action-section,
  .action-buttons-section,
  .stats-info {
    margin: 0 20rpx 20rpx;
    padding: 20rpx;
  }
  
  .feedback-list {
    padding: 0 20rpx;
  }
  
  .empty-state {
    margin: 20rpx;
    padding: 60rpx 20rpx;
  }
  
  .dish-name {
    font-size: 28rpx;
  }
  
  .feedback-preview {
    font-size: 26rpx;
  }
}