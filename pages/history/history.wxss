/* pages/history/history.wxss */
.history-container {
  min-height: 100vh;
  background: #F7F7F7;
}

/* 筛选标签 */
.filter-tabs {
  background: white;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-scroll {
  white-space: nowrap;
}

.filters {
  display: inline-flex;
  gap: 20rpx;
}

.filter-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  min-width: 120rpx;
}

.filter-item.active {
  background: #FFF5F0;
  border: 2rpx solid #FF672B;
}

.filter-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.filter-text {
  font-size: 24rpx;
  color: #666;
}

.filter-item.active .filter-text {
  color: #FF672B;
  font-weight: bold;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: white;
  margin-bottom: 20rpx;
}

.total-count {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.clear-btn {
  font-size: 26rpx;
  color: #FF672B;
  padding: 12rpx 24rpx;
  background: #FFF5F0;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
}

/* 历史记录列表 */
.history-list {
  height: calc(100vh - 300rpx);
  padding: 0 20rpx;
}

.history-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.type-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.type-label {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #999;
  padding: 6rpx 16rpx;
  background: #f9f9f9;
  border-radius: 6rpx;
}