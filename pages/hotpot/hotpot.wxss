/* pages/hotpot/hotpot.wxss */

/* 页面基础样式 */
page {
  min-height: 100vh;
  background-color: #F7F7F7;
}

.hotpot-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 分类头部 */
.category-header {
  background: white;
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.category-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1;
}

.category-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.category-desc {
  display: block;
  font-size: 28rpx;
  color: #999;
  line-height: 1.4;
}

/* 店铺列表区域 */
.shop-list {
  padding: 0 20rpx;
}

.shop-item {
  position: relative;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s ease;
}

.shop-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 100;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.favorite-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 1);
}

.favorite-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 店铺封面图片 */
.shop-cover {
  width: 100%;
  height: 300rpx;
  background-color: #f5f5f5;
  display: block;
}

/* 店铺信息区域 */
.shop-info {
  padding: 30rpx;
}

.shop-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.shop-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shop-rating {
  font-size: 28rpx;
  color: #FFB300;
  font-weight: bold;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.shop-address {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shop-price {
  display: block;
  font-size: 30rpx;
  color: #FF672B;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.shop-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
}

.tag {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  line-height: 1.2;
}

.tag:active {
  background: #e0e0e0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 30rpx;
  background: white;
  border-radius: 20rpx;
  margin: 30rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  font-weight: 500;
  line-height: 1.5;
}

/* 加载更多区域 */
.load-more {
  margin: 40rpx 20rpx 20rpx;
}

.load-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.loading-spinner {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #FF672B;
  border-radius: 50%;
  animation: loading 1s linear infinite;
  vertical-align: middle;
}

@keyframes loading {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.load-text {
  font-size: 30rpx;
  color: #FF672B;
  font-weight: 500;
  line-height: 1.2;
}

/* 没有更多提示 */
.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.no-more-text {
  position: relative;
  display: inline-block;
  padding: 0 40rpx;
  line-height: 1.2;
}

.no-more-text::before,
.no-more-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 60rpx;
  height: 1rpx;
  background: #eee;
}

.no-more-text::before {
  left: -40rpx;
}

.no-more-text::after {
  right: -40rpx;
}

/* 图片通用样式 */
image {
  background-color: #f5f5f5;
}

/* 卡片阴影效果 */
.category-header,
.shop-item,
.empty-state,
.load-content {
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .shop-name {
    font-size: 30rpx;
  }
  
  .shop-address {
    font-size: 26rpx;
  }
  
  .shop-price {
    font-size: 28rpx;
  }
  
  .category-title {
    font-size: 36rpx;
  }
}

/* 加载动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.shop-item {
  animation: fadeIn 0.5s ease-out;
  animation-fill-mode: both;
}

/* 为不同索引添加延迟动画 */
.shop-item:nth-child(1) { animation-delay: 0.1s; }
.shop-item:nth-child(2) { animation-delay: 0.2s; }
.shop-item:nth-child(3) { animation-delay: 0.3s; }
.shop-item:nth-child(4) { animation-delay: 0.4s; }
.shop-item:nth-child(5) { animation-delay: 0.5s; }
.shop-item:nth-child(6) { animation-delay: 0.6s; }

/* 页面进入动画 */
@keyframes pageIn {
  from { opacity: 0; transform: translateX(20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.hotpot-container {
  animation: pageIn 0.4s ease-out;
}

/* 返回按钮样式（如果需要） */
.back-button-container {
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.back-button {
  display: inline-flex;
  align-items: center;
  gap: 15rpx;
  padding: 16rpx 30rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s;
}

.back-button:active {
  background: #e0e0e0;
  transform: scale(0.98);
}

.back-icon {
  width: 30rpx;
  height: 30rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}