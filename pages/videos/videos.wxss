/* pages/videos/videos.wxss */
page {
  background-color: #F8F9FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.videos-container {
  min-height: 100vh;
  padding-bottom: 140rpx;
  position: relative;
}

/* ========== 视频列表 ========== */
.video-list {
  padding: 20rpx;
}

.video-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(173, 213, 162, 0.15);
  border: 3rpx solid rgba(173, 213, 162, 0.1);
  transition: all 0.3s;
}

.video-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(173, 213, 162, 0.2);
}

/* 作者信息和日期 */
.video-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx dashed #F0F0F0;
}

.author-info {
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #F0F0F0;
}

.author-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.video-date {
  font-size: 24rpx;
  color: #999;
}

/* 视频标题 */
.video-title-container {
  padding: 20rpx 30rpx;
}

.video-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 视频播放器区域 */
.video-player-container {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.video-player {
  width: 100%;
  height: 100%;
  background-color: #000;
}

.video-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.cover-image {
  width: 100%;
  height: 100%;
}

/* 播放按钮和时长 */
.play-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
}

.play-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.9;
}

.play-icon image {
  width: 100%;
  height: 100%;
}

.video-duration-overlay {
  color: #FFFFFF;
  font-size: 26rpx;
  background: rgba(0, 0, 0, 0.7);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

/* 视频描述和标签 */
.video-description {
  padding: 24rpx 30rpx;
  border-top: 2rpx dashed #F0F0F0;
}

.video-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.video-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 24rpx;
  color: #ADD5A2;
  background: rgba(173, 213, 162, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  display: inline-block;
  border: 1rpx solid rgba(173, 213, 162, 0.3);
}

.tag:active {
  background: rgba(173, 213, 162, 0.2);
  transform: scale(0.95);
}

/* 视频操作栏 */
.video-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  border-top: 2rpx dashed #F0F0F0;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  transition: transform 0.2s;
}

.action-item:active {
  transform: scale(0.9);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}

.like-icon {
  transition: transform 0.3s;
}

.action-count {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.view-stats {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.view-stats image {
  width: 20rpx;
  height: 20rpx;
}

/* ========== 悬浮按钮 ========== */
.floating-btn {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  background: linear-gradient(135deg, #FFB6C1, #FF8BA7);
  color: #FFFFFF;
  border-radius: 60rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 40rpx rgba(255, 182, 193, 0.4);
  z-index: 100;
  transition: all 0.3s;
}

.floating-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
}

.floating-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.floating-text {
  font-size: 32rpx;
  font-weight: 500;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .video-title {
    font-size: 30rpx;
  }
  
  .video-desc {
    font-size: 26rpx;
  }
  
  .author-name {
    font-size: 26rpx;
  }
  
  .video-date {
    font-size: 22rpx;
  }
}

/* 加载动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.video-item {
  animation: fadeIn 0.5s ease-out;
  animation-fill-mode: both;
}